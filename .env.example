# Deplo configuration. Copy to .env and fill in for local/production use.

# Root secret. REQUIRED in production. Derives all session signing and
# AES-256-GCM encryption keys, and is reused as the Better Auth secret.
# Generate one with: openssl rand -base64 48
DEPLO_SECRET=

# Public URL the dashboard is served from (used for cookies, TLS detection and
# the install command). Example: https://deplo.example.com
DEPLO_PUBLIC_URL=

# Public IPv4 of this server. Embedded into the zero-config sslip.io hostnames
# (<app>.<ip>.sslip.io) and the Traefik Host() router rule for every deployment,
# so it MUST be a literal, internet-reachable IPv4 — not a hostname. install.sh
# detects and sets this automatically; set it by hand for manual/dev runs.
# If unset, Deplo auto-detects the first non-internal NIC address and only falls
# back to 127.0.0.1 (which makes generated URLs reachable from this machine
# only) as a last resort. Example: 203.0.113.10
DEPLO_SERVER_IP=

# Postgres connection string. When set, Deplo uses Postgres as the system of
# record and enables Better Auth. When unset, a local JSON store is used.
# Example: postgres://deplo:password@localhost:5432/deplo
DEPLO_DATABASE_URL=

# Optional: cap the Postgres connection pool size (default 10).
# DEPLO_DATABASE_POOL_MAX=10

# Email used for Let's Encrypt certificates in the generated installer.
DEPLO_ACME_EMAIL=

# Name of the Traefik ACME cert resolver baked into every deployment's router
# `tls.certresolver` label. Defaults to `letsencrypt`. sslip.io domains require
# an HTTP-01 resolver (they cannot pass DNS-01 — sslip.io's DNS is not ours to
# edit); if your Traefik's default resolver uses DNS-01 (e.g. Cloudflare for a
# real domain), define a separate HTTP-01 resolver in Traefik and set its name
# here so sslip.io certs issue instead of serving Traefik's self-signed default.
# DEPLO_CERT_RESOLVER=letsencrypt

# Where the local JSON store lives when Postgres is not configured.
# DEPLO_DATA_DIR=./.deplo

# Base URL of the app repository — the remote catalog of installable apps
# (catalog.json + per-app manifests) the Apps page fetches read-only. Defaults
# to https://devrepo.pixelfederico.com. Override to point at a self-hosted
# repository.
# DEPLO_APP_REPO_URL=https://devrepo.pixelfederico.com
